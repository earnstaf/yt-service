# =========================================================
# yt-transcript-service environment configuration
# Copy to /opt/yt-transcript/.env on the VPS, mode 0600.
#
# NOTE: systemd's EnvironmentFile parser does NOT support trailing
# `# comment` after a value on the same line. Every comment must live
# on its own line BEFORE the variable. Keep that invariant when editing.
# =========================================================

# ---- Server ----
YT_BIND_HOST=127.0.0.1
YT_BIND_PORT=8765
YT_LOG_LEVEL=info
# production | dev | test
YT_ENV=production

# ---- Postgres (shared instance, dedicated DB/user) ----
DATABASE_URL=postgresql+asyncpg://yttranscript:CHANGE_ME@localhost/yt_transcript

# ---- Redis (shared instance, dedicated DB index) ----
REDIS_URL=redis://localhost:6379/3

# ---- Cache TTLs and limits ----
CACHE_TTL_DAYS=30
SUMMARY_CACHE_TTL_DAYS=90
MAX_VIDEO_DURATION_SECONDS=14400

# ---- Whisper ----
# openai | local
WHISPER_BACKEND=openai
WHISPER_OPENAI_MODEL=whisper-1
WHISPER_LOCAL_MODEL=base
WHISPER_FALLBACK_ON_OPENAI_ERROR=true
# 20MB; OpenAI Whisper limit is 25MB
WHISPER_CHUNK_BYTES=20971520

# ---- yt-dlp ----
YTDLP_TMP_DIR=/var/tmp/yt-transcript
YTDLP_MAX_FILESIZE_MB=500

# ---- Optional HTTPS proxy for YouTube captions/yt-dlp ----
# Works with Webshare residential, Zyte Smart Proxy Manager, etc.
# Format: http://USER:PASS@host:port
YT_HTTPS_PROXY=

# ---- LLM providers ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LLMAPI_API_KEY=
LLMAPI_BASE_URL=https://api.llmapi.ai/v1
HUGGINGFACE_TOKEN=

# ---- Cost guard ----
MAX_DAILY_LLM_COST_USD=10.00

# ---- Feature flags ----
# On by default for this build
FEATURE_SENTIMENT=true
FEATURE_DIARIZATION=true
FEATURE_MONITORS=true

# ---- Rate limits (per-token, can be overridden in tokens.rate_overrides) ----
RATE_LIMIT_READ=60/minute
RATE_LIMIT_BATCH=10/minute
RATE_LIMIT_SUMMARIZE=30/minute
RATE_LIMIT_INTELLIGENCE=20/minute
RATE_LIMIT_WHISPER=30/hour
RATE_LIMIT_MONITOR_CREATE=10/hour

# ---- Webhooks ----
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_TIMEOUT_SECONDS=10

# ---- Admin token (one-time bootstrap; rotate via CLI after first run) ----
# Leave empty in production; use `python -m app.admin tokens create` instead.
YT_BOOTSTRAP_ADMIN_TOKEN=
